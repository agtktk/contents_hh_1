---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostList from '../components/PostList.astro';
import { siteConfig } from '../../site.config.js';
import { getAllPosts } from '../lib/posts';

const posts = await getAllPosts();
const recentPosts = posts.slice(0, 6);
---

<BaseLayout title={siteConfig.siteName} description={siteConfig.siteDescription} canonicalPath="/">
  <section class="page-heading">
    <p class="eyebrow">SEO friendly static blog</p>
    <h1>{siteConfig.siteName}</h1>
    <p class="lead">{siteConfig.siteDescription}</p>
  </section>

  <div class="ad-slot">광고 배너 또는 공지 영역</div>

  <PostList posts={recentPosts} />
</BaseLayout>
